# Copia este archivo a `secrets.toml` (mismo directorio) y complétalo.
# `secrets.toml` está en .gitignore — nunca subir credenciales reales a git.

[gee]
# ID del proyecto GCP con la API de Earth Engine habilitada.
project = "ee-uhi-bogota"

# ── Desarrollo local ─────────────────────────────────────────────────────────
# Si vas a correr el dashboard en tu máquina y ya ejecutaste
# `earthengine authenticate` (guarda credenciales persistentes en
# ~/.config/earthengine), deja la sección [gee.service_account] completa
# comentada/ausente: app.py cae automáticamente a `ee.Initialize(project=...)`
# usando esas credenciales locales.

# ── Producción (Streamlit Cloud / Cloud Run) ────────────────────────────────
# Crea una service account en GCP con el rol "Earth Engine Resource Viewer"
# (o superior), genera una clave JSON y pega aquí sus campos tal cual:
#
# [gee.service_account]
# type = "service_account"
# project_id = "ee-uhi-bogota"
# private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# private_key = "-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
# client_email = "uhi-bogota@ee-uhi-bogota.iam.gserviceaccount.com"
# client_id = "123456789012345678901"
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/uhi-bogota%40ee-uhi-bogota.iam.gserviceaccount.com"
